# QuantClaw Dev Image
# Full source tree + build toolchain + pre-built artifacts, runs as root for convenience.
#
# Build:
#   docker build -f scripts/Dockerfile.dev -t quantclaw-dev .
# Run:
#   docker run -it --rm \
#     -p 18800:18800 -p 18801:18801 \
#     -v $(pwd):/app \
#     quantclaw-dev

FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

LABEL org.opencontainers.image.title="QuantClaw Dev" \
      org.opencontainers.image.description="QuantClaw development environment with full toolchain"

# ── 1. System dependencies ────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    curl \
    ca-certificates \
    libssl-dev \
    libcurl4-openssl-dev \
    nlohmann-json3-dev \
    libspdlog-dev \
    zlib1g-dev \
    jq \
    gdb \
    valgrind \
    && rm -rf /var/lib/apt/lists/*

# ── 2. Node.js 20 (for sidecar) ──────────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── 3. Copy source code ───────────────────────────────────────────────────────
# .dockerignore excludes: build/, node_modules/, refs/, .claude/, .git/, etc.
WORKDIR /app
COPY . .

# ── 4. Build C++ project ──────────────────────────────────────────────────────
RUN mkdir -p build && cd build \
    && cmake -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTS=ON .. \
    && make -j$(nproc) \
    && ln -sf /app/build/quantclaw /usr/local/bin/quantclaw \
    && ldd /app/build/quantclaw

# ── 5. Build Sidecar (Node.js) ───────────────────────────────────────────────
RUN cd sidecar \
    && npm ci \
    && npm run build

# ── 6. Runtime workspace layout (OpenClaw-compatible: agents/main/) ───────────
RUN mkdir -p /root/.quantclaw/agents/main/workspace \
             /root/.quantclaw/agents/main/sessions \
             /root/.quantclaw/logs

EXPOSE 18800 18801

# ── 7. Default: interactive shell to explore / build / test ───────────────────
CMD ["bash"]
