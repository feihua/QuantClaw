# QuantClaw Test Image
# Builds with tests enabled, runs unit tests + E2E tests.
#
# Build & run:
#   docker build -f scripts/Dockerfile.test -t quantclaw-test .
#   docker run --rm quantclaw-test
#   docker-compose -f scripts/docker-compose.yml run quantclaw-test

FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    ca-certificates \
    curl \
    libssl-dev \
    libcurl4-openssl-dev \
    nlohmann-json3-dev \
    libspdlog-dev \
    zlib1g-dev \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Node.js 20 for sidecar tests
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .

# Build C++ (tests enabled)
RUN mkdir -p build && cd build \
    && cmake -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTS=ON .. \
    && make -j$(nproc)

# Build Sidecar + its tests
RUN cd sidecar \
    && npm ci \
    && npm run build

# Normalize line endings + ensure scripts are executable
RUN find tests/ -name "*.sh" -exec sed -i 's/\r//' {} + \
    && chmod +x tests/e2e_test.sh 2>/dev/null || true

# Runtime workspace layout (OpenClaw-compatible: agents/main/)
RUN mkdir -p /root/.quantclaw/agents/main/workspace \
             /root/.quantclaw/agents/main/sessions \
             /root/.quantclaw/logs

# Entry: C++ unit tests → sidecar unit tests → CLI E2E
CMD ["bash", "-c", \
    "set -e && \
     echo '=== C++ unit tests ===' && cd /app/build && ./quantclaw_tests && \
     echo '=== Sidecar unit tests ===' && cd /app/sidecar && npm test && \
     echo '=== E2E tests ===' && cd /app && bash tests/e2e_test.sh"]
